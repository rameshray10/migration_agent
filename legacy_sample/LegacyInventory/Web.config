<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!-- ══════════════════════════════════════════════════════════════
       CONNECTION STRING — pure ADO.NET, no EF6
       Replace YOUR_SERVER with your SQL Server instance name.
       Examples:
         .\SQLEXPRESS          (SQL Server Express — most common)
         localhost             (default SQL Server instance)
         MYPC\SQLEXPRESS       (named instance)
       ══════════════════════════════════════════════════════════════ -->
  <connectionStrings>
    <add name="InventoryDB"
         connectionString="Server=YOUR_SERVER;Database=InventoryDB;Integrated Security=True;"
         providerName="System.Data.SqlClient" />
  </connectionStrings>

  <system.web>
    <compilation debug="true" targetFramework="4.8" />
    <httpRuntime targetFramework="4.8" />
  </system.web>
</configuration>
